# Production/PostgreSQL example:
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/smart_classroom
#
# Local fallback now works automatically with:
# DATABASE_URL=sqlite:///./smart_classroom.db
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/smart_classroom
JWT_SECRET=change-this-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
DEMO_ADMIN_EMAIL=admin@smartclassroom.local
DEMO_ADMIN_PASSWORD=Admin@123
